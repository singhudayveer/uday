pipeline {
    agent any

    stages {
        stage('Clone Repo') {
            steps {
               git'https://github.com/singhudayveer/uday.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t myapp .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 80:80 myapp'
            }
        }
   }
}
